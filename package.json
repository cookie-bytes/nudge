{
  "name": "@cookie-bytes/nudge",
  "version": "1.0.0",
  "description": "Deterministic C4 layout engine with optional AI polish",
  "bin": {
    "nudge": "./src/cli/index.js",
    "nudge-mcp": "./src/mcp/index.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "type": "module",
  "files": [
    "src/",
    "examples/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "UBIQUITOUS_LANGUAGE.md"
  ],
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');fs.mkdirSync('src/vendor',{recursive:true});fs.copyFileSync(require.resolve('elkjs/lib/elk.bundled.js'),'src/vendor/elk.bundled.js');\" && node -e \"const fs=require('fs'),s='scripts/generate_font_metrics.js';if(fs.existsSync(s))require('child_process').execFileSync(process.execPath,[s],{stdio:'inherit'});else if(!fs.existsSync('src/vendor/outfit_metrics.js'))throw new Error('outfit_metrics.js missing from package');\"",
    "start": "node src/cli/index.js examples/search_service_container.mermaid",
    "probe:apply-port-hints": "node scripts/port_hint_apply_probe.js",
    "probe:port-hints": "node scripts/port_hint_probe.js",
    "probe:apply-diagonal-routes": "node scripts/diagonal_route_apply_probe.js",
    "probe:diagonal-routes": "node scripts/diagonal_route_probe.js",
    "probe:apply-top-order": "node scripts/top_order_apply_probe.js",
    "probe:top-order": "node scripts/top_order_probe.js",
    "baseline:quality": "node scripts/capture_quality_baseline.js",
    "test:refactor": "node test/refactor_test_rig.js",
    "test:unit": "node --test test/unit/**/*.test.js",
    "test:integration": "node --test test/integration/**/*.test.js",
    "test:visual": "NUDGE_VISUAL_TEST=true node test/run_tests.js",
    "test": "npm run test:unit && npm run test:integration && node test/run_tests.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cookie-bytes/nudge.git"
  },
  "keywords": [
    "c4-model",
    "mermaid",
    "elkjs",
    "layout-optimization",
    "ai",
    "llm",
    "critic",
    "architecture-diagrams"
  ],
  "author": "Cookie Bytes",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cookie-bytes/nudge/issues"
  },
  "homepage": "https://github.com/cookie-bytes/nudge#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "elkjs": "0.9.3",
    "js-yaml": "^4.1.0",
    "playwright": "^1.44.1"
  },
  "devDependencies": {
    "@fontsource/outfit": "^5.3.0",
    "fontkit": "^2.0.4"
  }
}
