{
  "name": "@cookie-bytes/nudge",
  "version": "1.0.0",
  "description": "AI-driven layout optimizer for C4 Model architecture diagrams",
  "bin": {
    "nudge": "./src/cli/index.js",
    "nudge-mcp": "./src/mcp/index.js"
  },
  "type": "module",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');fs.mkdirSync('src/vendor',{recursive:true});fs.copyFileSync(require.resolve('elkjs/lib/elk.bundled.js'),'src/vendor/elk.bundled.js');\"",
    "start": "node src/cli/index.js examples/search_service_container.mermaid",
    "test": "node test/run_tests.js",
    "test:visual": "NUDGE_VISUAL_TEST=true node test/run_tests.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cookie-bytes/nudge.git"
  },
  "keywords": [
    "c4-model",
    "mermaid",
    "elkjs",
    "layout-optimization",
    "ai",
    "llm",
    "critic",
    "architecture-diagrams"
  ],
  "author": "Cookie Bytes",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cookie-bytes/nudge/issues"
  },
  "homepage": "https://github.com/cookie-bytes/nudge#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "elkjs": "0.9.3",
    "js-yaml": "^4.1.0",
    "playwright": "^1.44.1"
  }
}
