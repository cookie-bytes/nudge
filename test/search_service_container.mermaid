C4Container
    title Search Service
    caption Last modified: 2025-01-10

    %% External Systems / Applications outside the main boundary
    System(propel_white_label, "Propel White Label", "Front End Web Application", "Provides search and book capabilities to White Label users")
    System(distribution_api, "Distribution API", "Software System", "Provides Propel Public API to distribution partners such as Ryan Air, Easy Jet and OTB")
    System(cart_service, "Cart Service", "Software System", "Provides Propel cart management capabilities. Create cart, add item to cart, remove item to cart and validate cart.")
    System(integration_service, "Integration Service", "Software System", "Performs searches and bookings with 3rd party API providers and Cavu managed inventory API.")
    System(promotion_service, "Promotion Service", "Software System", "Provides Propel promotion management capabilities and applies promotion offers on search results")
    System(aws_eventbridge, "AWS EventBridge", "Software System", "AWS EventBridge serverless event bus that enables applications to communicate with each other using events.")
    System(partner_service_api, "Partner Service API", "Software System", "Manages Partner configuration and management in Propel")

    %% Search Service Boundary
    System_Boundary(search_service, "Search Service") {
        Container(search_api_gateway, "Search Service API Gateway", "AWS API Gateway", "Exposes Search Service APIs through API Gateway for external/internal consumers")
        Container(search_lambda, "Search Service Lambda", "PHP 8.2 Laravel Bref Lambda Function", "Handles search requests")
        ContainerDb(database, "Database", "AWS DynamoDB", "Stores search and availability results")
        Container(partner_sync_lambda, "Partner Sync Lambda", "NodeJS Lambda Function", "Handles partner data sync in search service")
    }

    %% Relationships
    Rel(propel_white_label, search_api_gateway, "make API calls to", "HTTPS")
    Rel(distribution_api, search_api_gateway, "make API calls to", "HTTPS")
    
    Rel(search_api_gateway, search_lambda, "makes API calls to", "HTTPS")
    
    Rel(search_lambda, database, "reads from and writes to", "TCP")
    Rel(search_lambda, cart_service, "makes API calls to", "HTTPS")
    Rel(search_lambda, integration_service, "makes API calls to", "HTTPS")
    Rel(search_lambda, promotion_service, "makes API calls to", "HTTPS")
    Rel(search_lambda, aws_eventbridge, "performs search requests via events and publishes search completed events", "")

    Rel(partner_sync_lambda, database, "reads from and writes to", "TCP")
    Rel(partner_sync_lambda, partner_service_api, "makes API calls to", "HTTPS")
    Rel(partner_sync_lambda, aws_eventbridge, "consumes Partner sync reference data events from", "")