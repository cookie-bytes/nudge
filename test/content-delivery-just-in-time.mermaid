C4Container
    title Content Delivery & Just-in-Time Transcoding Workflow
    caption Optimized for Ingest/Delivery Split

    System_Ext(cdn_edge, "CDN Edge", "External System", "Segment delivery to end users")
    System_Ext(drm_server, "DRM License Server", "External System", "Key issuance and management")

    System_Boundary(streaming_platform, "Streaming Platform") {
        Container(upload_svc, "Upload Service", "Go", "Ingests mezzanine assets")
        Container(playback_api, "Playback API", "Go", "Manifest & session orchestration")
        
        Container(orchestrator, "Workflow Orchestrator", "Java", "Transcode state machine")
        Container(transcode_worker, "Transcode Worker", "C++/FFmpeg", "Handles JIT renditions")
        Container(packaging_svc, "Packaging Service", "Go", "HLS/DASH packaging")
        
        ContainerQueue(job_queue, "Transcode Job Queue", "AWS SQS, local", "Manages transcode tasks")
        ContainerDb(session_cache, "Session Cache", "Redis", "Stores playback sessions")
        Container(catalog_svc, "Catalog Service", "Node.js", "Manages titles & metadata")
        Container(drm_adapter, "DRM Adapter", "Java", "License brokering")

        ContainerDb(asset_store, "Asset Store", "AWS S3", "Stores mezzanine & renditions")
        ContainerDb(catalog_store, "Catalog Store", "PostgreSQL", "Stores title metadata")
        
        ContainerQueue(workflow_events, "Workflow Events", "Kafka", "Asset lifecycle event backbone")
    }

    Rel(upload_svc, asset_store, "Stores mezzanine via", "S3 API")
    Rel(upload_svc, workflow_events, "Emits ingested event to", "Kafka")
    
    Rel(workflow_events, orchestrator, "Triggers workflow via", "Kafka")
    Rel(orchestrator, job_queue, "Enqueues transcode via", "SQS")
    Rel(orchestrator, catalog_svc, "Resolves title via", "gRPC")

    Rel(job_queue, transcode_worker, "Delivers job via", "SQS")
    Rel(transcode_worker, asset_store, "Reads/writes renditions via", "S3 API")
    Rel(transcode_worker, workflow_events, "Emits completed event to", "Kafka")

    Rel(workflow_events, packaging_svc, "Triggers packaging via", "Kafka")
    Rel(packaging_svc, asset_store, "Pulls segments via", "S3 API")
    Rel(packaging_svc, drm_adapter, "Gets license via", "gRPC")

    Rel(playback_api, session_cache, "Tracks session via", "RESP")
    Rel(playback_api, cdn_edge, "Returns manifest to", "HTTPS")
    Rel(drm_adapter, drm_server, "Issues key via", "HTTPS")

    Rel(catalog_svc, catalog_store, "Persists via", "JDBC")
    Rel(catalog_svc, workflow_events, "Publishes availability to", "Kafka")