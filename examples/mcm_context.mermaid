C4Context
    title C4 Context Diagram – MCM (Multi Channel Management)

    Person(salesOps, "Sales Operations Team", "Internal staff who configure and manage multi-channel sales activities, validate accounts, and fate vehicles")

    System(mcm, "MCM – Multi Channel Management", "Internal portal for configuring sales events, managing filtering criteria, and processing account registrations. Shared codebase with Manheim Website, independent deployment pipeline.")

    System(svv, "SVV – Single Vehicle View", "Core shared vehicle data service. Provides vehicle and account data to MCM and receives sales event data back.")
    System(website, "Manheim Website", "Auction marketplace. Displays sales events configured in MCM. Self-service registrations flow back to MCM for validation.")
    System(aims, "AIMS", "Branch operational system. Receives validated accounts from MCM and processes sold vehicle feeds for invoicing and allocation.")
    System(salesforce, "Salesforce", "CRM for sales-led account creation. Internally created accounts become visible in MCM via AIMS → SVV sync.")

    Rel(salesOps, mcm, "Configures sales events, validates registrations, fates vehicles on Sales Auth screen")

    Rel(mcm, svv, "Synchronises sales event data (SetSaleEvent)")
    Rel(svv, mcm, "Provides vehicle data and account registration data")
    Rel(mcm, website, "Publishes configured sales events for display")
    Rel(website, mcm, "Self-service registrations flow back for validation")
    Rel(mcm, aims, "Pushes validated accounts; sold feed triggers invoicing")
    Rel(salesforce, mcm, "Internally created accounts visible via AIMS → SVV sync")

    UpdateLayoutConfig($c4ShapeInRow="3", $c4BoundaryInRow="1")
