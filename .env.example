# Base URL of your OpenAI-compatible LLM API (LM Studio, Ollama, OpenRouter, etc.)
NUDGE_LLM_API=http://127.0.0.1:1234

# Model name to request. Nudge selects the closest match from the server's model list.
NUDGE_LLM_MODEL=google/gemma-4-12b

# API key sent as "Authorization: Bearer <key>". Leave unset for local servers.
NUDGE_LLM_API_KEY=

# Fallback API key if NUDGE_LLM_API_KEY is unset (standard OpenAI env var).
OPENAI_API_KEY=
